###
#1. Create BookingDto - 3 nights
POST {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "hotelId": {{hotelId}},
  "checkIn": "2026-01-14",
  "checkOut": "2026-01-16",
  "numberOfGuests": 2
}

###
#2. Create BookingDto - Different hotel, single night stay
POST {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "hotelId": {{hotelId}},
  "checkIn": "2026-01-14",
  "checkOut": "2026-01-15",
  "numberOfGuests": 1
}

###
#3. Create BookingDto - Invalid (CheckOut before CheckIn)
POST {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "hotelId": {{hotelId}},
  "checkIn": "2026-01-16",
  "checkOut": "2026-01-15",
  "numberOfGuests": 1
}

###
#4. Create BookingDto - Invalid (Guests<=0>)
POST {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "hotelId": {{hotelId}},
  "checkIn": "2026-01-14",
  "checkOut": "2026-01-15",
  "numberOfGuests": 0
}

###
#5. Create BookingDto - Conflict - Overlap test (use an earlier booking date)
POST {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "hotelId": {{hotelId}},
  "checkIn": "2026-01-14",
  "checkOut": "2026-01-15",
  "numberOfGuests": 1
}

###
#6 Update Booking
PUT {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking/{{bookingid}}
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "checkIn": "2026-01-15",
  "checkOut": "2026-01-19",
  "numberOfGuests": 1
}
###
#7 Admin confirm booking
PUT {{HotelListing.Api_HostAddress}}/api/hotels/{{hotelId}}/bookingsHotelBooking/{{bookingid}}/admin/confirm
Content-Type: application/json
Authorization: Bearer {{token}}
###

#List all bokings for hotel
